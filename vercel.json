{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/ingest/route.ts": {
      "maxDuration": 300
    }
  },
  "env": {
    "STUDYPACK_STORE": "memory"
  }
}
