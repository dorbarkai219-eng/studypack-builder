# Required for /ingest — Claude reads uploaded PDFs and structures them
# into a CoursePack JSON. Get a key at https://console.anthropic.com .
ANTHROPIC_API_KEY=

# Optional override. Defaults to claude-sonnet-4-5.
# ANTHROPIC_MODEL=claude-opus-4-7

# Pack store adapter. Choices: "fs" (default — data/packs/{id}.json) or
# "memory" (process-lifetime, serverless-friendly within a single instance).
# STUDYPACK_STORE=fs
