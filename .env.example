# Required for /ingest — Claude reads uploaded PDFs and structures them
# into a CoursePack JSON. Get a key at https://console.anthropic.com .
ANTHROPIC_API_KEY=

# Optional override. Defaults to claude-sonnet-4-5.
# ANTHROPIC_MODEL=claude-opus-4-7

# Pack store adapter. Choices: "fs" (default — data/packs/{userId}/{id}.json)
# or "memory" (process-lifetime, serverless-friendly within a single instance).
# STUDYPACK_STORE=fs

# Clerk auth (optional). When unset, the app runs in single-user dev mode
# and everything is reachable. When set, /ingest + /api/ingest +
# /api/packs/[id] require sign-in and each user gets their own pack
# namespace in the store.
#
# Both keys come from https://dashboard.clerk.com → API Keys.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_SECRET_KEY=sk_test_xxx
